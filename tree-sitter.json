{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "systemd",
      "camelcase": "Systemd",
      "title": "Systemd",
      "scope": "source.systemd",
      "file-types": [
        "service",
        "socket",
        "timer",
        "mount",
        "path",
        "slice",
        "scope",
        "target",
        "swap",
        "automount"
      ],
      "injection-regex": "^systemd$",
      "class-name": "TreeSitterSystemd"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Systemd grammar for tree-sitter",
    "authors": [
      {
        "name": "Benny"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-systemd"
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
